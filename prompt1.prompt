## 🧬 USER-PROFIL (State Schema)

Definiere in `lib/onboarding/profile.ts`:

```ts
export type UserStatus = 'explorer' | 'starter' | 'applicant' | 'pro'
export type InterviewGoal = 'spring_week' | 'summer' | 'full_time' | 'off_cycle' | 'unclear'
export type TimeFrame = '2_weeks' | '1_2_months' | '3_6_months' | 'more_6_months' | 'none'
export type ExplorerMotivation = 'money' | 'learning' | 'network' | 'unsure'
export type LearningTime = 'morning' | 'lunch' | 'evening' | 'flexible'
export type SkillProfile = 'A' | 'B' | 'C'  // A=Beginner, B=BWL-Vorkenntnisse, C=Profi-Drill

export interface UserProfile {
  status: UserStatus | null
  interviewGoal?: InterviewGoal
  timeFrame?: TimeFrame
  explorerMotivation?: ExplorerMotivation
  knowledge: {
    balance: 'correct' | 'wrong' | 'never_heard' | null
    ebitda: 'correct' | 'wrong' | 'never_heard' | null
    dcf: 'multiple' | 'once' | 'know_it' | 'never_heard' | null
  }
  skillProfile: SkillProfile | null
  learningTime: LearningTime | null
  streakStarted: string | null  // ISO date
  onboardingCompletedAt: string | null
}

export const STORAGE_KEY = 'career_dojo_profile'

export function getProfile(): UserProfile {
  if (typeof window === 'undefined') return getEmptyProfile()
  const raw = localStorage.getItem(STORAGE_KEY)
  return raw ? JSON.parse(raw) : getEmptyProfile()
}

export function saveProfile(profile: Partial<UserProfile>): void {
  const current = getProfile()
  const updated = { ...current, ...profile }
  localStorage.setItem(STORAGE_KEY, JSON.stringify(updated))
}

export function getEmptyProfile(): UserProfile {
  return {
    status: null,
    knowledge: { balance: null, ebitda: null, dcf: null },
    skillProfile: null,
    learningTime: null,
    streakStarted: null,
    onboardingCompletedAt: null,
  }
}

// Routing-Logik nach Knowledge-Check
export function calculateSkillProfile(knowledge: UserProfile['knowledge']): SkillProfile {
  // Profil C: Bereits DCF-Erfahrung
  if (knowledge.dcf === 'multiple') return 'C'
  
  const correctCount = [
    knowledge.balance === 'correct',
    knowledge.ebitda === 'correct',
  ].filter(Boolean).length
  
  const neverHeardCount = [
    knowledge.balance === 'never_heard',
    knowledge.ebitda === 'never_heard',
    knowledge.dcf === 'never_heard',
  ].filter(Boolean).length
  
  // Profil A: 2+ "noch nie gehört"
  if (neverHeardCount >= 2) return 'A'
  
  // Profil C: Beide richtig + DCF-Erfahrung
  if (correctCount === 2 && (knowledge.dcf === 'once' || knowledge.dcf === 'know_it')) return 'C'
  
  // Default: Profil B
  return 'B'
}

// Diagnostic-Daten für Slide 06
export function getDiagnosticData(profile: UserProfile) {
  const profileLabels: Record<SkillProfile, string> = {
    A: 'Entdecker',
    B: 'Einsteiger',
    C: 'Profi-Drill',
  }
  
  const goalLabels: Record<InterviewGoal, string> = {
    spring_week: 'Spring Week',
    summer: 'Summer Internship',
    full_time: 'Full-Time Position',
    off_cycle: 'Off-Cycle / Praktikum',
    unclear: 'Noch unklar',
  }
  
  // Lektionen-Anzahl basierend auf Profil
  const lessonsByProfile: Record<SkillProfile, number> = { A: 78, B: 47, C: 22 }
  
  // Empfohlene tägliche Zeit
  const dailyMinutes: Record<SkillProfile, number> = { A: 30, B: 30, C: 45 }
  
  // Wissensstand-Beschreibung
  const knowledgeDescription: Record<SkillProfile, string> = {
    A: 'Solider Start ohne Vorkenntnisse',
    B: 'Grundlagen sitzen, Vertiefung fehlt',
    C: 'Fortgeschritten, gezielter Drill nötig',
  }
  
  return {
    profileLabel: profileLabels[profile.skillProfile ?? 'B'],
    goalLabel: profile.interviewGoal ? goalLabels[profile.interviewGoal] : 'Erkundung',
    timeFrame: profile.timeFrame,
    knowledgeDescription: knowledgeDescription[profile.skillProfile ?? 'B'],
    lessonsCount: lessonsByProfile[profile.skillProfile ?? 'B'],
    dailyMinutes: dailyMinutes[profile.skillProfile ?? 'B'],
    weeksToTarget: profile.timeFrame === '2_weeks' ? 2
                 : profile.timeFrame === '1_2_months' ? 6
                 : profile.timeFrame === '3_6_months' ? 12
                 : 20,
  }
}
```

## 📐 ONBOARDING-LAYOUT

Erstelle `components/onboarding/OnboardingLayout.tsx`:

```tsx
interface OnboardingLayoutProps {
  currentStep: number       // 1-9
  totalSteps: number        // 9
  onBack?: () => void       // optional, nicht auf Slide 1
  footer: React.ReactNode
  children: React.ReactNode
  showProgress?: boolean    // default true, false auf Slide 1 (Cold Open ohne UI-Ablenkung)
}
```

Layout (verwendet das gleiche `h-screen flex flex-col`-Pattern wie das LessonLayout):

```tsx
<div className="h-screen flex flex-col bg-bg-primary">
  {/* Header */}
  <header className="h-12 flex-shrink-0 flex items-center px-6">
    {onBack && <button onClick={onBack}><ArrowLeft size={18} /></button>}
    {showProgress && <ProgressDots currentStep={currentStep} totalSteps={totalSteps} />}
  </header>

  {/* Main */}
  <main className="flex-1 overflow-y-auto">
    <div className="max-w-xl mx-auto px-6 py-8 lg:py-16">
      {children}
    </div>
  </main>

  {/* Footer */}
  <footer className="flex-shrink-0 px-6 py-4">
    <div className="max-w-xl mx-auto">
      {footer}
    </div>
  </footer>
</div>
```

**ProgressDots:** 9 kleine Kreise (8px), aktiv = `bg-accent`, abgeschlossen = `bg-text-muted`, kommend = `bg-bg-border`. Dezent, mittig im Header.

**Wichtig:** Auf Slide 1 (Cold Open) `showProgress={false}` setzen, damit die Konfrontation pur wirkt.

## 📋 SLIDES

### Slide 01 – Cold Open

Komponente: `Slide01ColdOpen.tsx`

Layout (kein Progress-Bar, kein Back-Button, vertikal mittig):

1. Großer Headline-Block mittig:
```tsx
   <h1 className="font-serif text-4xl md:text-5xl lg:text-6xl text-text-primary leading-tight">
     73% der IB-Bewerber scheitern am ersten Technical.
   </h1>
   <p className="font-serif italic text-xl md:text-2xl text-text-secondary mt-6">
     Nicht weil sie dumm sind. Weil sie falsch lernen.
   </p>
```

2. Footer-Slot enthält nur einen kleinen, dezenten Text-Button (kein großer CTA):
```tsx
   <button onClick={onNext} className="text-text-secondary hover:text-text-primary font-mono text-sm transition flex items-center gap-2">
     Erzähl mir mehr <ArrowRight size={14} />
   </button>
```

**Animation:** Headline fade-in mit leichtem y-offset (0 → -20px) bei Mount, 600ms.

**Mobile:** Headline `text-3xl`, Subline `text-lg`. Vertikales Padding angepasst.

### Slide 02 – Problem Diagnosis

Komponente: `Slide02ProblemDiagnosis.tsx`

Layout:

1. Marcus-Header (kompakt, ohne Avatar – nur Text):
```tsx
   <div className="font-mono text-xs text-text-muted tracking-wider uppercase">
     Marcus Hart
   </div>
   <div className="font-mono text-xs text-text-secondary italic mt-1">
     Ex-MD, 11 Jahre Goldman Sachs
   </div>
```

2. Quote (in Serif für Gewicht):
```tsx
   <blockquote className="font-serif text-2xl md:text-3xl text-text-primary mt-8 leading-snug">
     "In 11 Jahren habe ich über 2.000 Bewerber interviewt. Die meisten scheitern aus drei Gründen, und keiner davon ist mangelnde Intelligenz."
   </blockquote>
```

3. Drei Failure-Reasons als nummerierte Liste mit dünnem Akzent-Strich:
```tsx
   <ul className="mt-10 space-y-5">
     <li className="border-l-2 border-accent pl-4 py-1">
       <span className="font-mono text-xs text-accent block mb-1">01</span>
       <span className="text-text-primary">Sie cramen 4 Wochen vor dem Interview, statt täglich zu üben.</span>
     </li>
     {/* 02, 03 analog */}
   </ul>
```

   Items:
   - 01: "Sie cramen 4 Wochen vor dem Interview, statt täglich zu üben."
   - 02: "Sie pauken Antworten auswendig, statt das System zu verstehen."
   - 03: "Sie üben nie laut – und brechen unter Druck im echten Gespräch."

**Footer-CTA:** `Das passiert mir nicht →` (LessonFooterCTA-Komponente, primary)

### Slide 03 – Status Selection

Komponente: `Slide03StatusSelection.tsx`

Layout:

1. Headline: `**"Wo stehst du gerade?"**` (font-serif text-3xl md:text-4xl)
2. Sub-line: "Sei ehrlich – das hilft mir, dich richtig einzuschätzen." (text-text-secondary)
3. **Vier Optionskarten** (untereinander, voll breit):

```tsx
const options = [
  {
    id: 'explorer' as UserStatus,
    number: '01',
    label: 'ENTDECKER',
    description: 'Ich überlege noch, ob IB überhaupt mein Ding ist.',
  },
  {
    id: 'starter' as UserStatus,
    number: '02',
    label: 'EINSTEIGER',
    description: 'Ich weiß, dass ich es will – aber ich habe noch keine Ahnung, wo ich anfangen soll.',
  },
  {
    id: 'applicant' as UserStatus,
    number: '03',
    label: 'BEWERBER',
    description: 'Ich bewerbe mich aktiv – Spring Week, Summer, oder Off-Cycle.',
  },
  {
    id: 'pro' as UserStatus,
    number: '04',
    label: 'PROFI',
    description: 'Ich habe schon Praktikum-Erfahrung und drille gezielt für nächste Interviews.',
  },
]
```

Karten-Stil:
- Idle: `bg-bg-secondary border border-bg-border rounded-lg p-5 cursor-pointer hover:bg-bg-tertiary hover:border-text-muted transition-all`
- Selected: `border-accent bg-accent/5`
- Aufbau: Nummer (mono, accent-Farbe) oben, Label (mono, uppercase, tracking-wider, text-base) und Description (sans, text-sm text-text-secondary) darunter.

State: `useState<UserStatus | null>(null)`

**Footer-CTA:** `Weiter →` (disabled bis Auswahl getroffen). Bei Klick: Status in Profile speichern, dann `onNext()`.

### Slide 04 – Goal Selection (Conditional)

Komponente: `Slide04GoalSelection.tsx`

**Diese Slide hat zwei Varianten** je nach Status aus Slide 03.

**Variante A** (für `starter`, `applicant`, `pro`):

1. Headline: **"Worauf bereitest du dich vor?"**
2. Fünf Optionen als kompakte Buttons (`grid grid-cols-1 md:grid-cols-2 gap-3`):
   - Spring Week (Februar–April)
   - Summer Internship (Juni–August)
   - Full-Time Position
   - Off-Cycle / Praktikum
   - Noch unklar
3. Sub-Headline darunter: **"Wann ist dein nächstes Interview?"** (font-serif text-2xl, mit `mt-12`)
4. Fünf Optionen:
   - In den nächsten 2 Wochen
   - In 1–2 Monaten
   - In 3–6 Monaten
   - Mehr als 6 Monate
   - Noch keines geplant

**Variante B** (für `explorer`):

1. Headline: **"Was reizt dich am IB?"**
2. Vier Optionen (gleich gestylt wie Variante A):
   - Das Geld, ehrlich gesagt
   - Die Lernkurve und der Prestige
   - Das Netzwerk und Karriereperspektiven
   - Bin nicht sicher, will erstmal sehen, was das ist
3. **Keine zweite Frage** – Entdecker brauchen keinen Interview-Anker.

Button-Stil (für beide Varianten):
- Idle: `bg-bg-secondary border border-bg-border rounded-md px-4 py-3 text-sm cursor-pointer hover:bg-bg-tertiary transition-all`
- Selected: `border-accent bg-accent/10`

**Footer-CTA:** `Weiter →` (disabled bis ALLE Fragen der Variante beantwortet sind).

Bei Speichern: `interviewGoal`, `timeFrame` (Variante A) oder `explorerMotivation` (Variante B) in Profile.

### Slide 05 – Knowledge Check

Komponente: `Slide05KnowledgeCheck.tsx`

Layout:

1. Marcus-Pre-Frame oben:
```tsx
   <div className="border-l-2 border-accent pl-4 py-2 bg-bg-secondary rounded-r-lg">
     <div className="font-mono text-xs text-text-muted">MARCUS HART</div>
     <p className="text-text-primary italic mt-1">"Drei kurze Fragen – damit ich dich nicht mit Sachen langweile, die du schon kannst."</p>
   </div>
```

2. Drei Fragen untereinander (mit `mt-8 space-y-10`):

**Frage 1 – Bilanz:**
- Header: "Was zeigt eine Bilanz?" (font-serif text-xl)
- Optionen (4 Stück, gleicher Button-Stil wie Slide 04):
  - "Was eine Firma in einem Zeitraum verdient hat" → wrong
  - "Was eine Firma zu einem Stichtag besitzt und schuldet" → correct
  - "Wie viel Cash eine Firma generiert" → wrong
  - "Habe ich noch nie gehört" → never_heard

**Frage 2 – EBITDA:**
- Header: "Wofür steht EBITDA?"
- Optionen:
  - "Earnings Before Interest, Taxes, Depreciation and Amortization" → correct
  - "Estimated Business Income Tax Deduction Allowance" → wrong
  - "European Business Tax Indicator" → wrong
  - "Habe ich noch nie gehört" → never_heard

**Frage 3 – DCF:**
- Header: "Hast du schon mal ein DCF-Modell in Excel gebaut?"
- Optionen:
  - "Ja, mehrfach" → multiple
  - "Einmal, war kompliziert" → once
  - "Nein, aber ich weiß was es ist" → know_it
  - "Habe ich noch nie gehört" → never_heard

**Wichtig:** Alle drei Fragen sind sichtbar gleichzeitig, der User scrollt durch. Bei Auswahl glüht die Option in Akzent. Keine sofortige Bewertung (richtig/falsch) – das ist eine Diagnose, kein Test.

**Footer-CTA:** `Auswerten →` (disabled bis alle 3 Fragen beantwortet).

Bei Klick: 
1. Knowledge in Profile speichern
2. `calculateSkillProfile(knowledge)` aufrufen, Ergebnis in `skillProfile` speichern
3. `onNext()` triggern

### Slide 06 – Personalized Diagnosis

Komponente: `Slide06Diagnosis.tsx`

**Diese Slide ist der psychologische Höhepunkt des Onboardings** – hier zahlt sich die Investition des Users in die Diagnose aus.

Layout:

1. Headline: **"Hier ist meine Einschätzung."** (font-serif text-3xl)

2. **Diagnostic-Card im Bloomberg-Look** (font-mono):
```tsx
   <div className="bg-bg-secondary border border-bg-border rounded-xl p-6 mt-6 font-mono text-sm">
     <div className="space-y-3">
       <Row label="PROFIL"           value={data.profileLabel} />
       <Row label="ZIELINTERVIEW"    value={data.goalLabel} />
       <Row label="ZEITFENSTER"      value={data.timeFrame || '—'} />
       <Row label="WISSENSSTAND"     value={data.knowledgeDescription} />
     </div>
     
     <hr className="my-5 border-bg-border" />
     
     <div className="text-xs text-text-muted uppercase tracking-wider mb-3">EMPFOHLENER LERNPLAN</div>
     <div className="space-y-3">
       <Row label="Tägliche Übungszeit"        value={`${data.dailyMinutes} Min`} accent />
       <Row label="Lektionen bis Interview-ready" value={`${data.lessonsCount}`} accent />
       <Row label="Erste Lektion"              value="Income Statement" accent />
     </div>
   </div>
```

   Wo `Row` so aussieht:
```tsx
   <div className="flex justify-between items-center">
     <span className="text-text-secondary">{label}</span>
     <span className={accent ? 'text-accent' : 'text-text-primary'}>{value}</span>
   </div>
```

3. **Marcus-Block darunter** (im gewohnten MarcusNote-Stil):
   - Subject: dynamisch je nach Profil
   - Body: dynamisch je nach Profil

   Beispiele für Marcus-Texte:

   **Für Profil A (Entdecker/Beginner):**
   > "Du fängst bei Null an. Das ist okay – die meisten unterschätzen IB-Interviews und überschätzen ihr Wissen. Du machst es richtig herum. Mit 30 Minuten täglich bist du in 5 Monaten auf einem Niveau, auf dem du im First Round nicht panisch wirst. Es ist machbar. Es ist auch nicht optional – wer kürzer trainiert, fliegt zuverlässig raus."

   **Für Profil B (Einsteiger):**
   > "Du hast die Basics, aber dir fehlt die IB-spezifische Tiefe. Mit 30 Minuten täglich bist du in 12 Wochen auf einem Niveau, auf dem du im Summer-Interview nicht panisch wirst. Das ist machbar. Es ist auch nicht optional – wer kürzer trainiert, fliegt im First Round."

   **Für Profil C (Profi):**
   > "Du brauchst keine Erklärung mehr, du brauchst Drill. 45 Minuten täglich, gezielt auf deine Schwachstellen. Wenn du dranbleibst, hast du in 5 Wochen einen Vorteil gegenüber 90% der anderen Bewerber – nicht durch mehr Wissen, sondern durch mehr Reps."

   Implementiere das als Dictionary in `lib/onboarding/profile.ts`:
```ts
   export const MARCUS_DIAGNOSIS_TEXTS: Record<SkillProfile, { subject: string; body: string }> = {
     A: { subject: 'Re: Erste Einschätzung', body: '...' },
     B: { subject: 'Re: Erste Einschätzung', body: '...' },
     C: { subject: 'Re: Erste Einschätzung', body: '...' },
   }
```

**Footer-CTA:** `Plan annehmen →`

**Wichtig:** Der CTA-Text "Plan annehmen" ist nicht zufällig. Er ist eine Mikro-Verpflichtung. NICHT in "Weiter" ändern.

### Slide 07 – Identity Anchoring

Komponente: `Slide07IdentityAnchor.tsx`

Layout:

1. Headline (klein, leise): **"Eine Sache noch."** (font-serif text-2xl text-text-secondary)

2. Marcus-Quote (in Serif, groß):
```tsx
   <blockquote className="font-serif text-2xl text-text-primary mt-6 leading-snug">
     "Du wirst täglich eine Lektion machen. Nicht zwei, nicht drei. Eine. Manche Tage 5 Minuten, manche 30. Aber jeden Tag. Das ist die einzige Regel."
   </blockquote>
   <p className="font-serif italic text-text-secondary mt-4 text-lg">
     "Wer das durchzieht, schafft 90% der Konkurrenz – allein durch Konsequenz."
   </p>
```

3. **Lerntyp-Auswahl** mit Sub-Header:
```tsx
   <div className="mt-12">
     <h3 className="font-serif text-xl text-text-primary">Wann lernst du am besten?</h3>
     <p className="text-sm text-text-muted mt-1">Damit ich dich genau dann erinnere – nicht öfter.</p>
   </div>
```

4. **Vier Optionen** (Buttons, vertikal, gleicher Stil wie Slide 04):
   - Morgens vor der Uni *(7:00–9:00)*
   - In der Mittagspause *(12:00–13:00)*
   - Abends nach dem Tag *(20:00–22:00)*
   - Anders / wechselt

   Wichtig: Die Zeitangaben in Klammern sind in mono, kleiner.

State: `useState<LearningTime | null>(null)`

**Footer-CTA:** `Weiter →` (disabled bis Auswahl).

Bei Save: `learningTime` in Profile.

### Slide 08 – Streak Pre-Commitment

Komponente: `Slide08StreakCommit.tsx`

Layout:

1. Headline: **"Eine letzte Sache: Streaks."** (font-serif text-2xl)

2. **Animierte 7-Tage-Streak-Vorschau** mittig:
```tsx
   <div className="flex items-center justify-center gap-3 mt-12">
     {[1,2,3,4,5,6,7].map(day => (
       <div key={day} className={`
         w-10 h-10 rounded-full border-2 flex items-center justify-center
         transition-all duration-500
         ${day === 1 
           ? 'border-accent bg-accent/20 text-accent' 
           : 'border-bg-border text-text-muted'
         }
         font-mono text-sm
       `}>
         {day}
       </div>
     ))}
   </div>
```
   
   Animation: Tag 1 leuchtet bei Mount auf (Framer Motion: scale 0 → 1 + Akzent-Glow), die anderen 6 erscheinen mit Stagger-Delay.

3. **Erklärungs-Text:**
```tsx
   <div className="mt-12 space-y-5 text-text-primary">
     <p>Ab morgen läuft dein Streak. Jeden Tag, an dem du eine Lektion abschließt, wächst er.</p>
     <p>Wenn du einen Tag aussetzt, beginnt er bei Null. Klingt hart, ist aber psychologisch der einzige Mechanismus, der nachweislich funktioniert.</p>
     <p className="font-serif italic text-lg text-text-secondary border-l-2 border-accent pl-4 py-2">
       Dein Ziel der ersten Woche: 7 Tage in Folge. Das ist alles. Keine Lektion-Targets, keine XP. Nur 7 Tage.
     </p>
   </div>
```

**Footer-CTA:** `Bin dabei →`

Bei Klick: `streakStarted` in Profile auf morgen setzen (oder heute, wenn der User direkt die erste Lektion macht – siehe Slide 9).

### Slide 09 – First Lesson Hook

Komponente: `Slide09FirstLessonHook.tsx`

Layout:

1. Headline mittig, groß: **"Bereit?"** (font-serif text-5xl)

2. **Lesson-Preview-Card** (orientiert sich exakt an der Lesson-Stat-Card aus der Lektion):
```tsx
   <div className="bg-bg-secondary border border-bg-border rounded-xl p-6 mt-12">
     <div className="font-mono text-xs text-text-muted tracking-wider uppercase mb-3">
       Deine erste Lektion
     </div>
     <h3 className="font-serif text-3xl text-text-primary">Income Statement</h3>
     <p className="text-text-secondary mt-1">Gewinn- und Verlustrechnung</p>
     
     <div className="grid grid-cols-3 gap-4 mt-6 pt-5 border-t border-bg-border">
       <div>
         <div className="font-mono text-xs text-text-muted uppercase">Dauer</div>
         <div className="font-mono text-2xl text-text-primary mt-1">6 MIN</div>
       </div>
       <div>
         <div className="font-mono text-xs text-text-muted uppercase">Schwierig.</div>
         <div className="font-mono text-2xl text-text-primary mt-1">★☆☆☆☆</div>
       </div>
       <div>
         <div className="font-mono text-xs text-text-muted uppercase">XP</div>
         <div className="font-mono text-2xl text-accent mt-1">+25</div>
       </div>
     </div>
   </div>
```

3. **Marcus-Quote (kurz, knapp):**
```tsx
   <blockquote className="font-serif italic text-xl text-text-secondary mt-8 text-center">
     "Sechs Minuten. Eine Lektion. Dann hast du Tag 1 deines Streaks. Los."
   </blockquote>
```

**Footer-CTA:** `Lektion starten →` (groß, accent, mit Pfeil-Icon)

Bei Klick:
1. `onboardingCompletedAt` auf jetzt setzen
2. `streakStarted` auf heute setzen (User startet sofort)
3. Router-Navigation zu `/lesson/income-statement`

## 🧠 STATE MACHINE (page.tsx)

```tsx
'use client'
import { useState, useEffect } from 'react'
import { useRouter } from 'next/navigation'
import { OnboardingLayout } from '@/components/onboarding/OnboardingLayout'
import {
  getProfile,
  saveProfile,
  calculateSkillProfile,
  type UserProfile,
} from '@/lib/onboarding/profile'

import Slide01ColdOpen from '@/components/onboarding/Slide01ColdOpen'
import Slide02ProblemDiagnosis from '@/components/onboarding/Slide02ProblemDiagnosis'
// ... alle 9 Imports

const SLIDES = [
  Slide01ColdOpen,
  Slide02ProblemDiagnosis,
  Slide03StatusSelection,
  Slide04GoalSelection,
  Slide05KnowledgeCheck,
  Slide06Diagnosis,
  Slide07IdentityAnchor,
  Slide08StreakCommit,
  Slide09FirstLessonHook,
] as const

export default function OnboardingPage() {
  const router = useRouter()
  const [currentStep, setCurrentStep] = useState(0)
  const [profile, setProfileState] = useState<UserProfile>(getProfile())

  // Skip onboarding if already completed
  useEffect(() => {
    if (profile.onboardingCompletedAt) {
      router.push('/lesson/income-statement')
    }
  }, [profile.onboardingCompletedAt, router])

  const updateProfile = (partial: Partial<UserProfile>) => {
    saveProfile(partial)
    setProfileState(prev => ({ ...prev, ...partial }))
  }

  const goNext = () => setCurrentStep(s => Math.min(s + 1, SLIDES.length - 1))
  const goBack = () => setCurrentStep(s => Math.max(s - 1, 0))

  const Slide = SLIDES[currentStep]
  const isFirstSlide = currentStep === 0

  return (
    <OnboardingLayout
      currentStep={currentStep + 1}
      totalSteps={9}
      onBack={isFirstSlide ? undefined : goBack}
      showProgress={!isFirstSlide}
      footer={null}  // wird vom Slide selbst gerendert via Render-Prop oder context
    >
      <Slide
        profile={profile}
        updateProfile={updateProfile}
        onNext={goNext}
      />
    </OnboardingLayout>
  )
}
```

**Wichtig zur Footer-Architektur:** Da jeder Slide seinen eigenen Footer-CTA braucht (mit unterschiedlichen Validations und Labels), übergibt das `OnboardingLayout` den Footer als Slot, und jeder Slide rendert sein eigenes `<LessonFooterCTA>` darin. Verwende dafür entweder einen React Context oder Render-Props – am saubersten ist:

```tsx
// Slide rendert sich selbst inkl. Footer in einem Fragment:
return (
  <>
    {/* Slide-Content kommt in Layout's main */}
    <SlideContent />
    
    {/* Footer wird via Portal in den Footer-Slot teleportiert */}
    <FooterPortal>
      <LessonFooterCTA onClick={handleNext} disabled={!isValid} label="Weiter →" />
    </FooterPortal>
  </>
)
```

Setze einen Footer-Portal-Mechanismus mit React's `createPortal` auf, der einen Footer-Slot im Layout adressiert.

## 🎯 PUSH NOTIFICATION (Post-Onboarding, optional)

Nach Abschluss der ersten Lektion (NICHT direkt nach Onboarding) zeigst du Push-Permission. Implementiere das als separaten Hook:

```ts
// hooks/usePushPermission.ts
export function usePushPermission() {
  const requestPermission = async () => {
    if (!('Notification' in window)) return 'denied'
    return await Notification.requestPermission()
  }
  return { requestPermission }
}
```

Nach Lesson-1-Completion zeige ein Modal mit Marcus-Stimme:

> *"Soll ich dich morgen erinnern? Genau zur Zeit, die du gewählt hast – nicht öfter."*
> 
> [Erlauben] [Nein danke]

**Wichtig:** Das ist NICHT Teil dieses Prompts (Phase Onboarding). Implementiere nur den Hook und einen Marker im Profile (`pushPermissionAsked: boolean`), der beim nächsten Lesson-Complete-Event geprüft wird.

## ✅ ACCEPTANCE CRITERIA

1. User kann das gesamte Onboarding in unter 90 Sekunden durchklicken
2. Nach Slide 5 wird `skillProfile` korrekt berechnet (A/B/C-Logik)
3. Slide 4 zeigt zwei verschiedene Varianten je nach `status` aus Slide 3
4. Slide 6 zeigt personalisierte Marcus-Texte je nach `skillProfile`
5. Profil wird in localStorage persistiert (`career_dojo_profile`)
6. Wenn User Onboarding bereits abgeschlossen hat (Profile hat `onboardingCompletedAt`), wird er direkt zu `/lesson/income-statement` weitergeleitet
7. Bei Klick auf "Lektion starten" in Slide 9 wird der User zur Lektion navigiert
8. **Mobile (375px):** Alle Slides funktionieren ohne horizontalen Scroll
9. **Desktop (1440px):** Content ist auf `max-w-xl` zentriert, leere Seiten wirken durch klare Typografie nicht leer
10. Marcus' Tonfall ist durchgehend scharf-direkt, niemals "weichgespült"
11. Keine 3D-Emojis, keine Cartoon-Elemente
12. Animationen niemals länger als 600ms

## 🚀 IMPLEMENTIERUNGS-REIHENFOLGE

1. **Branch erstellen** + Profile-Schema in `lib/onboarding/profile.ts` anlegen
2. **OnboardingLayout** + Footer-Portal-Mechanismus
3. **Slide 01** Cold Open (psychologisch wichtigster Hook)
4. **Slide 02** Problem Diagnosis
5. **Slide 03** Status Selection
6. **Slide 04** Goal Selection (conditional rendering!)
7. **Slide 05** Knowledge Check + `calculateSkillProfile`-Logik
8. **Slide 06** Diagnosis (mit allen drei Marcus-Varianten)
9. **Slide 07** Identity Anchor
10. **Slide 08** Streak Pre-Commitment (mit Animation)
11. **Slide 09** First Lesson Hook
12. **Routing:** `app/onboarding/page.tsx` als State Machine
13. **Skip-Logic:** Wenn Profile.onboardingCompletedAt existiert, direkt zur Lektion weiterleiten
14. **App-Root anpassen:** Initial-Route soll zu `/onboarding` führen, wenn kein Profile vorhanden ist
15. **Mobile-Testing** auf 375px, 768px, 1440px
16. **Push & PR**

Frag mich nach jedem implementierten Slide, ob ich Änderungen will, bevor du zum nächsten gehst.

Wenn du einen besseren psychologischen Hook für eine Slide siehst (z.B. eine schärfere Marcus-Quote, eine elegantere Animation), schlage ihn aktiv vor. Aber halte dich strikt an:
- Den scharfen, direkten Marcus-Tonfall (keine Hype-Sprache)
- Das etablierte Design-System (keine neuen Farben)
- Die psychologische Architektur (Diagnose → Routing → Commitment → Identity → Erste Lektion)

Los geht's mit Schritt 1 (Branch + Profile-Schema).