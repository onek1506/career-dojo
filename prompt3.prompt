## 📊 DATEN UND LOGIK

In `lib/stats/stats-utils.ts`:

```ts
import { getUserState } from '@/lib/home/user-state'
import { LESSON_REGISTRY } from '@/lib/home/lesson-registry'

// Skill-Level-Bezeichnungen im IB-Sprech
export const LEVEL_LABELS: Record<number, { title: string; description: string }> = {
  1: {
    title: 'Analyst in Training',
    description: 'Accounting-Grundlagen im Aufbau.',
  },
  2: {
    title: 'Junior Analyst',
    description: 'Accounting abgeschlossen. Valuation-Einstieg.',
  },
  3: {
    title: 'Associate-Niveau',
    description: 'Valuation und DCF verstanden.',
  },
  4: {
    title: 'Senior Analyst',
    description: 'M&A und LBO-Grundlagen sitzen.',
  },
  5: {
    title: 'Interview-Ready',
    description: 'Vollständige technische Vorbereitung.',
  },
}

// Stärken/Schwächen basierend auf Quiz-Performance
export interface TopicPerformance {
  topic: string
  score: number       // 0–100
  attempts: number
  status: 'strong' | 'weak' | 'untested'
}

export function getTopicPerformance(): TopicPerformance[] {
  const raw = localStorage.getItem('career_dojo_quiz_performance')
  const data = raw ? JSON.parse(raw) : {}

  const topics = [
    'Income Statement',
    'Balance Sheet',
    'Cash Flow Statement',
    'Die 3 Statements',
    'Enterprise Value',
    'Valuation',
    'DCF',
    'M&A',
    'LBO',
  ]

  return topics.map(topic => {
    const perf = data[topic]
    if (!perf) return { topic, score: 0, attempts: 0, status: 'untested' }
    const score = Math.round((perf.correct / perf.total) * 100)
    return {
      topic,
      score,
      attempts: perf.total,
      status: score >= 80 ? 'strong' : 'weak',
    }
  })
}

export function getXpByLesson(): { lessonTitle: string; xp: number }[] {
  const raw = localStorage.getItem('career_dojo_xp_history')
  return raw ? JSON.parse(raw) : []
}
```

## 🖥️ STATS PAGE (`app/stats/page.tsx`)

```tsx
'use client'
import { useEffect, useState } from 'react'
import { getUserState } from '@/lib/home/user-state'
import { LEVEL_LABELS, getTopicPerformance, getXpByLesson } from '@/lib/stats/stats-utils'
import { SkillLevelCard } from '@/components/stats/SkillLevelCard'
import { StrengthsWeaknessMatrix } from '@/components/stats/StrengthsWeaknessMatrix'
import { XpProgressCard } from '@/components/stats/XpProgressCard'
import { TotalStatsRow } from '@/components/stats/TotalStatsRow'
import { BottomNav } from '@/components/home/BottomNav'

export default function StatsPage() {
  const [state, setState] = useState<ReturnType<typeof getUserState> | null>(null)
  const [topicPerf, setTopicPerf] = useState<ReturnType<typeof getTopicPerformance>>([])

  useEffect(() => {
    setState(getUserState())
    setTopicPerf(getTopicPerformance())
  }, [])

  if (!state) return <LoadingScreen />

  const levelInfo = LEVEL_LABELS[state.currentLevel]

  return (
    <div className="min-h-screen bg-bg-primary flex flex-col">
      <main className="flex-1 overflow-y-auto pb-24">
        <div className="max-w-2xl mx-auto px-6 pt-10 space-y-6">

          {/* Page Header */}
          <div>
            <p className="font-mono text-xs text-text-muted uppercase tracking-wider">
              DEINE ENTWICKLUNG
            </p>
            <h1 className="font-serif text-4xl text-text-primary mt-2">
              Statistik
            </h1>
          </div>

          {/* Skill Level */}
          <SkillLevelCard
            level={state.currentLevel}
            title={levelInfo.title}
            description={levelInfo.description}
            totalXp={state.totalXp}
            nextLevelXp={getNextLevelXp(state.currentLevel)}
          />

          {/* Total Stats */}
          <TotalStatsRow
            streak={state.streakDays}
            completedLessons={state.completedLessons.length}
            totalXp={state.totalXp}
          />

          {/* Stärken / Schwächen */}
          <StrengthsWeaknessMatrix topics={topicPerf} />

          {/* XP Progress */}
          <XpProgressCard history={getXpByLesson()} />

        </div>
      </main>
      <BottomNav activeTab="stats" />
    </div>
  )
}

function getNextLevelXp(currentLevel: number): number {
  const thresholds = [200, 500, 1000, 2000, Infinity]
  return thresholds[currentLevel - 1] ?? Infinity
}
```

