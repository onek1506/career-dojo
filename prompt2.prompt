    value: -12,
  },
  {
    type: 'main',
    label: 'Net Income',
    de: 'Jahresüberschuss',
    explanation: 'Was am Ende für die Aktionäre übrig bleibt. Bottom-Line.',
    value: 18,
    barWidth: 18,
    highlighted: true,
  },
