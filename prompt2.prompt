## рҹ“Ұ ROUTING & STATE-MANAGEMENT

### `app/lesson/income-statement/page.tsx`

```tsx
'use client'
import { useState } from 'react'
import { useRouter } from 'next/navigation'
import { LessonLayout } from '@/components/lesson/LessonLayout'
import Slide01Briefing from '@/components/lesson/income-statement/Slide01Briefing'
// ... alle 12 Slide-Imports

type QuizResult = { correct: boolean; attempts: number }
type QuizResults = {
  q1: QuizResult | null
  q2: QuizResult | null
  q3: QuizResult | null
  q4: QuizResult | null
}

const SLIDES = [
  Slide01Briefing,
  Slide02BalanceVsIS,
  Slide03Waterfall,
  Slide04Margins,
  Slide05FormulaDrill,
  Slide06CheatSheet,
  Slide07ProTips,
  Slide08QuizSort,
  Slide09QuizCalc,
  Slide10QuizMultiSelect,
  Slide11QuizHierarchy,
  Slide12Retention,
] as const

export default function IncomeStatementLessonPage() {
  const router = useRouter()
  const [currentStep, setCurrentStep] = useState(0)
  const [quizResults, setQuizResults] = useState<QuizResults>({
    q1: null, q2: null, q3: null, q4: null
  })
  const [startTime] = useState(Date.now())
  const [canProceed, setCanProceed] = useState(false)

  const totalXp = calculateTotalXp(quizResults)
  const elapsedSeconds = Math.floor((Date.now() - startTime) / 1000)
  const accuracy = calculateAccuracy(quizResults)

  const Slide = SLIDES[currentStep]

  return (
    <LessonLayout
      currentStep={currentStep + 1}
      totalSteps={12}
      onBack={() => currentStep > 0 ? setCurrentStep(s => s - 1) : router.back()}
      onNext={() => setCurrentStep(s => s + 1)}
      nextDisabled={!canProceed}
    >
      <Slide
        onAnswer={(slideKey: keyof QuizResults, result: QuizResult) =>
          setQuizResults(prev => ({ ...prev, [slideKey]: result }))
        }
        onCanProceed={setCanProceed}
        onNext={() => setCurrentStep(s => s + 1)}
        // Nur an Slide12 Гјbergeben:
        results={currentStep === 11 ? { quizResults, totalXp, elapsedSeconds, accuracy } : undefined}
      />
    </LessonLayout>
  )
}
```

### XP-Berechnungs-Logik

```ts
// lib/lesson/xp.ts
export function calculateTotalXp(results: QuizResults): number {
  let xp = 5 // Lesson-Completion-Bonus

  const xpMap = {
    q1: { full: 10, half: 5 },
    q2: { full: 10, half: 5 },
    q3: { full: 15, half: 8 },
    q4: { full: 15, half: 8 },
  }

  for (const [key, result] of Object.entries(results)) {
    if (!result || !result.correct) continue
    const points = xpMap[key as keyof typeof xpMap]
    xp += result.attempts === 1 ? points.full : points.half
  }

  return xp
}

export function calculateAccuracy(results: QuizResults): number {
  const total = Object.values(results).filter(r => r !== null).length
  if (total === 0) return 0
  const correct = Object.values(results).filter(r => r?.correct).length
  return Math.round((correct / total) * 100)
}
```

